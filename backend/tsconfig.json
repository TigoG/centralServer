{
  "compilerOptions": {
    "lib": [
      "es2024",
      "ESNext.Array",
      "ESNext.Collection",
      "ESNext.Iterator",
      "ESNext.Promise",
      "DOM"
    ],
    "module": "nodenext",
    "target": "es2024",

    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node16",

    "outDir": "./dist",
    "rootDir": "./src"
    
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules/"]
}
